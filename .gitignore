__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
venv/
logs/*
!logs/.gitkeep
*.eval
.env
.vscode/
.idea/
.DS_Store
*.lock
uv.lock
HANDOFF.md

# Assembled benchmark outputs (ephemeral — regenerate with scripts/assemble_tier.py).
# Source files in test_data/inventories/ and test_data/test_cases/ are tracked.
test_data/*.ndjson
test_data/*.yaml

# Directory contents excluded (may contain sensitive data).
# The directories themselves are tracked via .gitkeep.
# Sample/example files will be added explicitly with git add -f.
configs/*
!configs/.gitkeep
reports/*
!reports/.gitkeep
